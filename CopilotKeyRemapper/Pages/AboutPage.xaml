<Page
    x:Class="CopilotKeyRemapper.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
    <StackPanel MaxWidth="1000" Margin="16">
        <TextBlock Text="About" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <!-- App identity -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE946;" FontSize="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Copilot Key Remapper" FontSize="16" FontWeight="Medium"/>
                    <TextBlock x:Name="VersionText" FontSize="12" Opacity="0.6"/>
                    <TextBlock Text="Choose what your keyboard's Copilot key does — send a custom shortcut, open an app, or run a Windows function."
                               FontSize="13" Opacity="0.6" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- How it works -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE897;" FontSize="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="How it works" FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="Registers as an official Microsoft Copilot hardware-key provider. Pressing the key launches a tiny handler that runs your action and exits — no background service, no tray icon, nothing resident."
                               FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Built With -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE943;" FontSize="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Built With" FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="WinUI 3 · .NET 10 · Windows App SDK · CommunityToolkit.Mvvm · NLog"
                               FontSize="12" Opacity="0.5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Source Code -->
        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE12B;" FontSize="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Source Code" FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="View the project on GitHub" FontSize="12" Opacity="0.5"/>
                </StackPanel>
                <HyperlinkButton Grid.Column="2" Content="GitHub Repository"
                                 NavigateUri="https://github.com/RyanEwen/CopilotKeyRemapper" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Updates -->
        <Border x:Name="UpdateCard" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE895;" FontSize="24" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Updates" FontSize="14" FontWeight="Medium"/>
                    <TextBlock x:Name="UpdateStatusText" Text="Click to check for updates" FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                </StackPanel>
                <Button x:Name="CheckUpdateButton" Grid.Column="2" Content="Check for Updates" Click="CheckForUpdates_Click" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </StackPanel>
    </Grid>
    </ScrollViewer>
</Page>
